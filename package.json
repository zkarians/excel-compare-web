{
  "dependencies": {
    "cors": "^2.8.6",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.2",
    "pg": "^8.20.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^28.2.10",
    "electron-builder": "^24.13.3",
    "wait-on": "^7.2.0"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "serve": "node server.js",
    "build": "cross-env NODE_NO_WARNINGS=1 electron-builder --win --x64"
  },
  "build": {
    "npmRebuild": false,
    "appId": "com.excelcompare.app",
    "productName": "ExcelCompare",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "portable",
        "nsis"
      ]
    },
    "files": [
      "server.js",
      "main.js",
      "preload.js",
      "index.html",
      "app_main.js",
      "style.css",
      "js/",
      "css/",
      "services/",
      "masterrule/",
      "master_data/",
      "data/",
      "build/",
      "node_modules/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*"
    ]
  },
  "name": "excelcompare",
  "version": "1.1.1",
  "engines": {
    "node": ">=18"
  },
  "description": "Excel Data Comparison Application with Built-in Server",
  "author": "User"
}